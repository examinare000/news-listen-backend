FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ ./shared/
COPY jobs/ ./jobs/

# JOB_MODULE 環境変数で実行するジョブを切り替える
# 例: JOB_MODULE=jobs.rss_fetcher.main
# 未設定のまま起動すると原因不明のクラッシュになるため、明示的なエラーで即座に失敗させる。
CMD ["sh", "-c", "if [ -z \"$JOB_MODULE\" ]; then echo 'ERROR: JOB_MODULE environment variable is not set' >&2; exit 1; fi; exec python -m \"$JOB_MODULE\""]
