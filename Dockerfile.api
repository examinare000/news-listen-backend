FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ ./shared/
COPY api/ ./api/

# 非root ユーザーで実行し、コンテナ侵害時の権限を最小化する。
# COPY 済みファイルは world-readable のため appuser から読み取り可能。
# ポート 8080 は非特権ポートなので bind に root は不要。
RUN useradd --create-home appuser
USER appuser

EXPOSE 8080
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8080"]
