# --- CORS ---
# 許可するオリジンをカンマ区切りで指定。未設定/空は「全拒否」（安全側デフォルト）。"*" は使用不可。
CORS_ALLOWED_ORIGINS=
# --- Security Headers ---
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=no-referrer
# HSTS は本番 HTTPS のみ。ローカル HTTP を壊さないため既定は無効。
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
# --- Rate Limiting ---
# ログイン試行レート制限。0 で無効化。
LOGIN_RATELIMIT_MAX_ATTEMPTS=5
LOGIN_RATELIMIT_WINDOW_SECONDS=900
LOGIN_RATELIMIT_LOCKOUT_SECONDS=900
# API グローバルレート制限（全エンドポイント）。0 で無効化。
API_RATELIMIT_MAX_REQUESTS=120
API_RATELIMIT_WINDOW_SECONDS=60
# Star エンドポイント専用レート制限。0 で無効化。
STAR_RATELIMIT_MAX_REQUESTS=10
STAR_RATELIMIT_WINDOW_SECONDS=3600
