# --- CORS ---
# 許可するオリジンをカンマ区切りで指定。未設定/空は「全拒否」（安全側デフォルト）。"*" は使用不可。
CORS_ALLOWED_ORIGINS=
# --- Security Headers ---
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=no-referrer
# HSTS は本番 HTTPS のみ。ローカル HTTP を壊さないため既定は無効。
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
# --- Rate Limiting ---
# ログイン試行レート制限。0 で無効化。
LOGIN_RATELIMIT_MAX_ATTEMPTS=5
LOGIN_RATELIMIT_WINDOW_SECONDS=900
LOGIN_RATELIMIT_LOCKOUT_SECONDS=900
# API グローバルレート制限（全エンドポイント）。0 で無効化。
API_RATELIMIT_MAX_REQUESTS=120
API_RATELIMIT_WINDOW_SECONDS=60
# Star エンドポイント専用レート制限。0 で無効化。
STAR_RATELIMIT_MAX_REQUESTS=10
STAR_RATELIMIT_WINDOW_SECONDS=3600
# --- CSRF Protection (Double-submit Cookie) ---
# CSRF 保護の有効化。本番環境で true。ローカル/テストは false（既定）。
CSRF_PROTECTION_ENABLED=false
# CSRF チェック免除パス（カンマ区切り）。未設定は既定セット（login・password reset・passkey login）へ縮退。
CSRF_EXEMPT_PATHS=/auth/login,/auth/password/forgot,/auth/password/reset,/auth/passkey/login/options,/auth/passkey/login/verify
# --- Web Push (VAPID) ---
# VAPID 公開鍵・秘密鍵（web-push generate-vapid-keys で生成）。
# 実値は本番の Secret Manager へ。未設定で NoOpNotifier に自動降格。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID クレーム署名用メールアドレス。
VAPID_CLAIMS_EMAIL=contact@example.com
# --- iOS Push (APNs / token-based provider) ---
# APNs 認証キー(.p8)の本文（PEM）。改行を含むため Secret Manager で管理し、実値はコミットしない。
# 4 つ（PRIVATE_KEY / KEY_ID / TEAM_ID / BUNDLE_ID）が揃わなければ APNs は自動で no-op。
APNS_PRIVATE_KEY=
# Apple Developer の Key ID（.p8 発行時に表示）。
APNS_KEY_ID=
# Apple Developer の Team ID。
APNS_TEAM_ID=
# アプリの Bundle ID（apns-topic に使う）。例: com.rioikeda.news-listen
APNS_BUNDLE_ID=
# 開発ビルド（aps-environment=development）へ送る場合は true。本番は未設定/false。
APNS_USE_SANDBOX=false
# --- Authentication & Session ---
# セッション有効期間（時間）。既定 168（7日）。api/routers/auth.py が参照。
SESSION_TTL_HOURS=168
# セッション Cookie の Secure 属性。本番 HTTPS では true、ローカル http では false。
SESSION_COOKIE_SECURE=true
# セッション一覧 UI 用 last_used_at のスロットル間隔（秒）。既定 300（5分）。
# 認証経路は高頻度なため、この間隔を超えた場合のみ last_used_at を書き込みコストを抑える。
SESSION_LASTUSED_THROTTLE_SECONDS=300
# --- Initial User Seed (scripts/seed_users.py) ---
# 起動時 seed する初期 admin / user の資格情報。実値はコミットせず環境で与える。
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASS=
INITIAL_USER_USERNAME=
INITIAL_USER_PASSWORD=
# --- Password Reset (self-service, issue #45) ---
# リセットトークンの寿命（分）。既定 30。短命にして漏洩時の窓を最小化。
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# /auth/password/forgot のレート制限（IP 単位）。0 で無効化（既定）。
PASSWORD_RESET_RATELIMIT_MAX_REQUESTS=0
PASSWORD_RESET_RATELIMIT_WINDOW_SECONDS=3600
# リセットリンクのベース URL（フロントの再設定画面）。`?token=...` を付与して送信。
PASSWORD_RESET_URL_BASE=https://app.example.com/reset-password
# --- Email Sender (SMTP, password reset) ---
# 全て揃えば SmtpEmailSender、未設定なら NoOpEmailSender に自動降格（ローカル/テスト安全）。
# 実値は本番の Secret Manager へ。
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# --- Passkey / WebAuthn (FIDO2, issue #77) ---
# RP ID: ブラウザが送るオリジンのホスト部分と一致させる。未設定で passkey 機能を無効化（503）。
# 例: 本番では news-listen.example.com、ローカルでは localhost。
WEBAUTHN_RP_ID=
# RP 名: Authenticator の UI に表示されるサービス名。
WEBAUTHN_RP_NAME=News Listen
# 許可するオリジン（カンマ区切りで複数指定可）。WEBAUTHN_RP_ID に対応する https:// URL。
# 例: https://news-listen.example.com,https://app.news-listen.example.com
# ローカル http: http://localhost
WEBAUTHN_ORIGIN=https://news-listen.example.com
# チャレンジタイムアウト（ミリ秒）。既定 60000（1分）。
WEBAUTHN_TIMEOUT_MS=60000
