# --- CORS ---
# 許可するオリジンをカンマ区切りで指定。未設定/空は「全拒否」（安全側デフォルト）。"*" は使用不可。
CORS_ALLOWED_ORIGINS=
# --- Security Headers ---
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=no-referrer
# HSTS は本番 HTTPS のみ。ローカル HTTP を壊さないため既定は無効。
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
# --- Rate Limiting ---
# ログイン試行レート制限。0 で無効化。
LOGIN_RATELIMIT_MAX_ATTEMPTS=5
LOGIN_RATELIMIT_WINDOW_SECONDS=900
LOGIN_RATELIMIT_LOCKOUT_SECONDS=900
# API グローバルレート制限（全エンドポイント）。0 で無効化。
API_RATELIMIT_MAX_REQUESTS=120
API_RATELIMIT_WINDOW_SECONDS=60
# Star エンドポイント専用レート制限。0 で無効化。
STAR_RATELIMIT_MAX_REQUESTS=10
STAR_RATELIMIT_WINDOW_SECONDS=3600
# --- CSRF Protection (Double-submit Cookie) ---
# CSRF 保護の有効化。本番環境で true。ローカル/テストは false（既定）。
CSRF_PROTECTION_ENABLED=false
# CSRF チェック免除パス（カンマ区切り）。未設定は既定 "/auth/login" へ縮退。
CSRF_EXEMPT_PATHS=/auth/login
# --- Web Push (VAPID) ---
# VAPID 公開鍵・秘密鍵（web-push generate-vapid-keys で生成）。
# 実値は本番の Secret Manager へ。未設定で NoOpNotifier に自動降格。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID クレーム署名用メールアドレス。
VAPID_CLAIMS_EMAIL=contact@example.com
# --- Authentication & Session ---
# セッション有効期間（時間）。既定 168（7日）。api/routers/auth.py が参照。
SESSION_TTL_HOURS=168
# セッション Cookie の Secure 属性。本番 HTTPS では true、ローカル http では false。
SESSION_COOKIE_SECURE=true
# --- Initial User Seed (scripts/seed_users.py) ---
# 起動時 seed する初期 admin / user の資格情報。実値はコミットせず環境で与える。
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASS=
INITIAL_USER_USERNAME=
INITIAL_USER_PASSWORD=
